# ==============================================================================
# Jd2Job — Backend Environment Variables Template
# Copy this file to '.env' and fill in your actual production credentials.
# ==============================================================================

# Server configuration
PORT=3001
# Comma-separated list of allowed browser origins (your Vercel frontend + localhost for dev)
CORS_ORIGIN=http://localhost:5173,https://jd2job.com

# ── AI Provider API Keys ──────────────────────────────────────────────────────
# Speech-to-text / Voice agent (REQUIRED — used by the WS proxies /api/deepgram*)
DEEPGRAM_API_KEY=your-deepgram-api-key-here
# Primary LLM (REQUIRED — copilot answers, interview agents, extension AI)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# Fast/fallback LLM providers (optional but recommended — used for llama_fast mode,
# chat fallbacks, and the extension tailor-resume/answer chain: DeepSeek → NVIDIA → Groq)
GROQ_API_KEY=gsk_your-groq-api-key-here
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here
# Vision model for screen reading (optional — falls back to NVIDIA, then DeepSeek)
TOGETHER_AI_KEY=your-together-api-key-for-vision
TOGETHER_AI_URL=https://api.together.ai/v1/chat/completions
# Text-to-speech (optional — /api/tts/* endpoints)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ── Supabase (Settings → API in your Supabase dashboard) ─────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Razorpay (https://dashboard.razorpay.com/app/keys) ───────────────────────
# Payments are disabled until both are set. Plan prices are fixed server-side:
# base=₹999 (5 credits), topup=₹249 (1 credit), monthly=₹3999, quarterly=₹9999.
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ── Optional ──────────────────────────────────────────────────────────────────
# Custom fast-model endpoint (e.g. local Ollama http://localhost:11434/v1/chat/completions)
# If omitted, fast requests route to Groq 8B / NVIDIA Llama 3.1 8B.
LLAMA_FAST_API_URL=
LLAMA_FAST_MODEL_NAME=

# Public URL of the downloadable desktop app installer (used by /api/download)
DESKTOP_APP_DOWNLOAD_URL=
