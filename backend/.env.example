# ==============================================================================
# Interview Copilot — Backend Environment Variables Template
# Copy this file to '.env' and fill in your actual production credentials.
# ==============================================================================

# Server configuration
PORT=3001
CORS_ORIGIN=http://localhost:5173,https://your-production-app.com

# AI Provider API Keys
DEEPGRAM_API_KEY=your-deepgram-api-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
TOGETHER_AI_KEY=your-together-api-key-for-vision

# Supabase database credentials (retrieve from Supabase dashboard -> Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Optional Fast Model API URL (e.g. local Ollama instance http://localhost:11434/v1/chat/completions)
# If omitted, the server automatically routes fast requests to the Nvidia Llama 3.1 8B endpoint.
LLAMA_FAST_API_URL=
LLAMA_FAST_MODEL_NAME=
