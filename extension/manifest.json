{
  "manifest_version": 3,
  "name": "Jd2Job — AI Auto Apply & Resume Tailoring",
  "version": "2.0.0",
  "description": "Auto-apply to LinkedIn Easy Apply jobs with AI-generated, JD-tailored resumes and smart form answers. Syncs every application to your Jd2Job dashboard.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://jd2job.com/*",
    "https://*.jd2job.com/*",
    "https://*.supabase.co/*",
    "https://api.deepseek.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/shared/utils.js", "src/shared/dom.js", "src/shared/api-client.js", "src/shared/ai.js", "src/shared/storage.js", "content-simple.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://jd2job.com/*",
        "https://*.jd2job.com/*",
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["content-portal.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
