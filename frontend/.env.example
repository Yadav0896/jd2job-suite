# ==============================================================================
# Interview Copilot — Frontend Environment Variables Template
# Copy this file to '.env' and fill in your actual production credentials.
# ==============================================================================

# Supabase Configuration (anon key is safe for client-side exposure)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Backend API URL (use the domain where your backend server is deployed)
VITE_API_URL=https://api.your-production-app.com
