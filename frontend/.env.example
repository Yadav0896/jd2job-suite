# ==============================================================================
# Jd2Job — Frontend Environment Variables Template
# Copy this file to '.env' (local dev) or set these in Vercel → Project →
# Settings → Environment Variables (production).
# ==============================================================================

# Supabase Configuration (anon key is safe for client-side exposure)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Backend API URL — your Railway deployment, e.g. https://your-app.up.railway.app
# IMPORTANT: voice features (Interview Copilot, Mock Interview) connect over
# WebSocket to <VITE_API_URL>/api/deepgram* — this must point DIRECTLY at the
# Railway backend, NOT at https://jd2job.com, because Vercel rewrites cannot
# proxy WebSocket upgrades. Plain REST calls can still go through the
# /api/* rewrite in vercel.json, but setting VITE_API_URL to Railway directly
# keeps everything on one origin and is the recommended setup.
VITE_API_URL=http://localhost:3001

# Razorpay publishable key id (safe for client-side exposure — used by checkout.js)
VITE_RAZORPAY_KEY_ID=rzp_live_your-key-id
